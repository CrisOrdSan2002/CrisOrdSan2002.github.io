<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XV Isabella - Bosque Encantado</title>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
    
    <style>
        :root {
            /* Degradado azul para las tarjetas según image_73105f.jpg */
            --azul-glass: linear-gradient(135deg, rgba(10, 37, 64, 0.5), rgba(2, 6, 23, 0.7));
            --dorado: #d4af37;
            --blanco: rgba(255, 255, 255, 0.95);
        }

        body, html {
            margin: 0;
            padding: 0;
            font-family: 'Montserrat', sans-serif;
            color: white;
            /* Eliminamos el background-color sólido que causaba el error */
            scroll-behavior: smooth;
        }

        /* ----- FONDO DEL BOSQUE - SIEMPRE VISIBLE ----- */
        .forest-fixed {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* Imagen de bosque encantado estable */
            background-image: url('https://images.pexels.com/photos/167699/pexels-photo-167699.jpeg?auto=compress&cs=tinysrgb&w=1920');
            background-size: cover;
            background-position: center;
            z-index: -2;
        }

        /* Filtro sutil para no opacar el bosque */
        .forest-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.1);
            z-index: -1;
        }

        /* ----- PARTÍCULAS (POLVO MÁGICO / LUCIÉRNAGAS) ----- */
        #magic-particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        .sparkle {
            position: absolute;
            background: radial-gradient(circle, #fff, var(--dorado));
            border-radius: 50%;
            box-shadow: 0 0 10px var(--dorado);
            opacity: 0;
        }

        /* ----- SECCIONES DISTRIBUIDAS ----- */
        .content-scroll {
            position: relative;
            z-index: 10;
        }

        section {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 50px 20px;
            box-sizing: border-box;
        }

        /* TARJETAS CON DEGRADADO AZUL Y TRANSPARENCIA */
        .glass-card {
            background: var(--azul-glass);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 2px solid var(--dorado);
            border-radius: 25px;
            padding: 50px 30px;
            max-width: 600px;
            width: 100%;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
            opacity: 0; /* Para la animación de aparición */
        }

        h1.main-name {
            font-family: 'Great Vibes', cursive;
            font-size: clamp(4rem, 12vw, 6.5rem);
            color: var(--dorado);
            margin: 0;
            text-shadow: 0 0 20px rgba(212, 175, 55, 0.5);
        }

        .label-top {
            text-transform: uppercase;
            letter-spacing: 6px;
            font-size: 0.9rem;
            color: var(--dorado);
            font-weight: 700;
            margin-bottom: 20px;
            display: block;
        }

        p { font-size: 1.2rem; line-height: 1.7; color: var(--blanco); }

        /* ----- CONTADOR ESTILO image_73105f.jpg ----- */
        .countdown-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin: 40px 0;
        }

        .unit-box {
            background: rgba(0, 0, 0, 0.4);
            padding: 20px 5px;
            border-radius: 15px;
            border: 1px solid rgba(212, 175, 55, 0.4);
        }

        .num { font-size: 2.2rem; font-weight: 700; color: var(--dorado); display: block; }
        .lab { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.9; }

        .btn-magic {
            display: inline-block;
            padding: 18px 40px;
            background-color: #1e3a8a;
            color: white;
            text-decoration: none;
            border-radius: 50px;
            border: 2px solid var(--dorado);
            font-weight: 700;
            transition: all 0.3s ease;
        }

        .btn-magic:hover {
            background-color: var(--dorado);
            color: #020621;
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
        }

        .gift-number-display {
            font-size: 2.2rem;
            letter-spacing: 6px;
            color: var(--dorado);
            font-weight: 700;
            display: block;
            margin-top: 15px;
        }
    </style>
</head>
<body>

    <div class="forest-fixed"></div>
    <div class="forest-overlay"></div>
    <div id="magic-particles"></div>

    <div class="content-scroll">
        
        <!-- PARTE 1: NOMBRE -->
        <section>
            <div class="glass-card">
                <span class="label-top">Mis XV Años</span>
                <h1 class="main-name">Isabella</h1>
                <p>Te espero para compartir la magia de una noche inolvidable.</p>
            </div>
        </section>

        <!-- PARTE 2: PADRES Y VESTIDO -->
        <section>
            <div class="glass-card">
                <span class="label-top">Con la bendición de mis padres</span>
                <p><strong>David Alvarez Hernández</strong><br><strong>Mariana Padron Hernández</strong></p>
                <div style="margin-top: 35px; border-top: 1px solid var(--dorado); padding-top: 25px;">
                    <p>Sábado 25 de Julio, 2026<br>Código de Vestimenta: Gala<br><span style="color:var(--dorado); font-weight: 700;">Vestido Azul</span></p>
                </div>
            </div>
        </section>

        <!-- PARTE 3: CUENTA REGRESIVA Y MAPA -->
        <section>
            <div class="glass-card">
                <span class="label-top">Faltan solo...</span>
                <div class="countdown-grid">
                    <div class="unit-box"><span class="num" id="d">00</span><span class="lab">Días</span></div>
                    <div class="unit-box"><span class="num" id="h">00</span><span class="lab">Hrs</span></div>
                    <div class="unit-box"><span class="num" id="m">00</span><span class="lab">Min</span></div>
                    <div class="unit-box"><span class="num" id="s">00</span><span class="lab">Seg</span></div>
                </div>
                <a href="https://maps.app.goo.gl/ZSfrUSWCbdUYPX4E7" target="_blank" class="btn-magic">VER UBICACIÓN</a>
            </div>
        </section>

        <!-- PARTE 4: REGALOS -->
        <section>
            <div class="glass-card">
                <span class="label-top">Mesa de Regalos</span>
                <p>Tu presencia es mi mejor regalo, pero si deseas obsequiarme algo:</p>
                <span class="gift-number-display">52001872</span>
            </div>
        </section>

    </div>

    <script>
        // 1. LÓGICA DEL CONTADOR (25 de Julio de 2026)
        const targetDate = new Date("July 25, 2026 18:00:00").getTime();
        setInterval(() => {
            const now = new Date().getTime();
            const diff = targetDate - now;
            document.getElementById("d").innerText = Math.floor(diff / 86400000);
            document.getElementById("h").innerText = Math.floor((diff % 86400000) / 3600000);
            document.getElementById("m").innerText = Math.floor((diff % 3600000) / 60000);
            document.getElementById("s").innerText = Math.floor((diff % 60000) / 1000);
        }, 1000);

        // 2. ANIMACIÓN DE PARTÍCULAS "BOSQUE ENCANTADO"
        const pContainer = document.getElementById('magic-particles');
        for (let i = 0; i < 70; i++) {
            const sparkle = document.createElement('div');
            sparkle.className = 'sparkle';
            sparkle.style.width = sparkle.style.height = anime.random(3, 7) + 'px';
            sparkle.style.left = anime.random(0, 100) + 'vw';
            sparkle.style.top = anime.random(0, 100) + 'vh';
            pContainer.appendChild(sparkle);
        }

        anime({
            targets: '.sparkle',
            translateX: () => anime.random(-120, 120),
            translateY: () => anime.random(-150, 50),
            opacity: [0, 0.8, 0],
            scale: [0, 1.3, 0],
            duration: () => anime.random(4000, 8000),
            delay: anime.stagger(100),
            loop: true,
            easing: 'easeInOutQuad'
        });

        // 3. REVELACIÓN DE TARJETAS AL HACER SCROLL
        const obs = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if(entry.isIntersecting) {
                    anime({
                        targets: entry.target,
                        opacity: [0, 1],
                        translateY: [50, 0],
                        duration: 1200,
                        easing: 'easeOutQuart'
                    });
                }
            });
        }, { threshold: 0.2 });

        document.querySelectorAll('.glass-card').forEach(card => obs.observe(card));
    </script>
</body>
</html>
